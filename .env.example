# Supabase — public/client-safe (exposed to browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Supabase — server-only (NEVER expose to client; used for cron + server actions)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...  # fetch from Supabase dashboard → Project Settings → API

# Vercel Cron secret (generate yourself; Vercel sends it in Authorization header)
CRON_SECRET=generate-a-random-string-32-chars-or-longer
